# Macro file for the initialization of example B1
# in interactive session
#
# Set some default verbose
/control/verbose 2
/run/verbose 2

##################### G4State_PreInit ###################

/MultiDetector1/detectors/BB7/addGeometryTo WaterBox 0


# ================= Phase Space settings ===============

/MultiDetector1/beamline/clinac/phsp/clearFiles
/MultiDetector1/beamline/clinac/phsp/addFile **PhspFileName**
/MultiDetector1/beamline/clinac/setJaw1X **Jaw1X** cm
/MultiDetector1/beamline/clinac/setJaw2X **Jaw2X** cm
/MultiDetector1/beamline/clinac/setJaw1Y **Jaw1Y** cm
/MultiDetector1/beamline/clinac/setJaw2Y **Jaw2Y** cm
/MultiDetector1/beamline/clinac/rotateGantry **GantryAngle** deg
/MultiDetector1/beamline/clinac/rotateCollimator **CollimatorAngle** deg

##################### Initialization ###################
#
# Initialize kernel
/run/initialize
/run/printProgress 10000
#

##################### G4State_Idle ###################

# ==================== Beam settings ==================

/MultiDetector1/run/SetMU 100
/MultiDetector1/beamline/clinac/rotateGantryPhSp **GantryAngle** deg
/MultiDetector1/beamline/clinac/rotateCollimatorPhSp **CollimatorAngle** deg


# ================== Geometry settings ================

/MultiDetector1/phantoms/waterbox/phantomID 0
/MultiDetector1/phantoms/waterbox/translateTo 0 0 10 cm

/MultiDetector1/detectors/BB7/detectorID 0
/MultiDetector1/detectors/BB7/translateTo 0 0 -10 cm
/MultiDetector1/detectors/BB7/rotateX **DetectorAngle** deg

# ================== Scoring settings =================
# Primitive scorers
/control/execute mac/scorers1.mac
