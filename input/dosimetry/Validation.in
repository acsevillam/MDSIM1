# Macro file for the initialization of example B1
# in interactive session
#
# Set some default verbose
/control/verbose 0
/run/verbose 0

##################### G4State_PreInit ###################

# ================= Phase Space settings ===============

/MultiDetector1/beamline/clinac/phsp/clearFiles
/MultiDetector1/beamline/clinac/phsp/setPrefix beam/Varian_TrueBeam6MV_
/MultiDetector1/beamline/clinac/setJaw1X 5 cm
/MultiDetector1/beamline/clinac/setJaw2X 5 cm
/MultiDetector1/beamline/clinac/setJaw1Y 5 cm
/MultiDetector1/beamline/clinac/setJaw2Y 5 cm

##################### Initialization ###################
#
# Initialize kernel
/run/initialize
/run/printProgress 10000
#

##################### G4State_Idle ###################

# ==================== Beam settings ==================

/MultiDetector1/run/SetMU 1


# ================== Geometry settings ================

/MultiDetector1/phantoms/waterbox/phantomID 0
/MultiDetector1/phantoms/waterbox/translateTo 0 0 -10 cm # SSD = 100 cm

# ================== Scoring settings =================

# Primitive scorers
/control/execute mac/scorers1.mac

/score/create/boxMesh pddBuildup
/score/mesh/boxSize 0.25 0.25 0.8 cm
/score/mesh/translate/xyz 0 0 -0.8 cm
/score/mesh/nBin 1 1 32 // x y z
/score/quantity/doseDeposit dose
/score/close

/score/create/boxMesh pdd
/score/mesh/boxSize 0.25 0.25 20. cm
/score/mesh/translate/xyz 0 0 -20 cm
/score/mesh/nBin 1 1 80 // x y z
/score/quantity/doseDeposit dose
/score/close

/score/create/boxMesh latProfile_y
/score/mesh/boxSize 0.25 20. 0.25 cm
/score/mesh/translate/xyz 0 0 -2.5 cm
/score/mesh/nBin 1 80 1 // x y z
/score/quantity/doseDeposit dose
/score/close

/score/create/boxMesh latProfile_x
/score/mesh/boxSize 20 0.25 0.25 cm
/score/mesh/translate/xyz 0 0 -2.5 cm
/score/mesh/nBin 80 1 1 // x y z
/score/quantity/doseDeposit dose
/score/close
